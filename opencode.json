{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "coder": {
      "description": "Lập trình viên chính, code và sửa lỗi theo feedback",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "reviewer": {
      "description": "Code reviewer, góp ý và phản biện code",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
